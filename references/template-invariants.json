        "poster-wall",
        "paper",
        "stamp",
        "rule"
      ],
      "deckObjects": [
        "archive-cover",
        "folio-grid",
        "plate-grid",
        "quote-page",
        "closing"
      ],
      "roleMarkers": {
        "cover": "archive-cover",
        "proof": "folio-grid",
        "mechanism": "plate-grid",
        "close": "closing"
      },
