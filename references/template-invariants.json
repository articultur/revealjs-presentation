    "examples/template-03-minimal-spatial.html": {
      "domain": "architecture / spatial product narrative",
      "designGrammar": "architectural plate, title block, dimension chains, measured floor plan, section cut",
      "coverClass": "spatial-cover",
      "coverObjects": [
        "blueprint-sheet",
        "plan-drawing",
        "dimension-chain",
        "plate-notes",
        "title-block",
        "north-mark"
      ],
      "deckObjects": [
        "section-cut",
        "cutaway",
        "matrix",
        "void-page",
        "route"
      ],
      "roleMarkers": {
        "cover": "spatial-cover",
        "proof": "section-cut",
        "mechanism": "matrix",
        "close": "void-page"
      },
      "physicalContract": {
        "version": 1,
        "purpose": "Architectural plates are physical drawing sheets: the grid field, plan, dimensions, notes, bottom title band, and title block must use declared ownership and collision rules rather than independent absolute coordinates.",
        "surfaceRules": [
          {
            "name": "blueprint-field-owns-drawing-objects",
            "surface": ".blueprint-sheet",
            "contents": [
              ".plan-drawing",
              ".dimension-chain",
              ".plate-notes"
            ],
            "maxSpillPx": 2,
            "requireOwnership": true
          },
          {
            "name": "bottom-band-owns-title-objects",
            "surface": ".cover-bottom",
            "contents": [
              ".cover-title-area",
              ".title-block"
            ],
            "maxSpillPx": 2,
            "requireOwnership": true
          }
        ],
        "exclusionRules": [
          {
            "name": "title-block-must-not-enter-grid-field",
            "a": ".title-block",
            "b": ".blueprint-sheet",
            "maxIntersectionArea": 1
          }
        ],
        "alignmentRules": [
          {
            "name": "dimension-chain-aligns-with-outer-wall",
            "type": "horizontalEdges",
            "subject": ".dimension-chain",
            "target": ".plan-drawing svg rect[stroke-width=\"3\"]",
            "maxDeltaPx": 10
          }
        ],
        "placementRules": [
          {
            "name": "plan-stays-left-up-inside-grid-field",
            "subject": ".plan-drawing",
            "container": ".blueprint-sheet",
            "maxLeftInsetPx": 150,
            "maxTopInsetPx": 170,
            "minBottomClearancePx": 40
          }
        ],
        "collisionRules": [
          {
            "name": "plan-markers-do-not-cover-room-labels",
            "scope": ".plan-drawing",
            "a": "svg circle[fill=\"var(--c-accent)\"]",
            "b": "svg text",
            "bTextPattern": "FOYER|READING|CORE|STUDIO|WORK",
            "maxIntersectionWidthPx": 2,
            "maxIntersectionHeightPx": 2
          }
        ]
      },
      "forbidden": [
        "block a",
        "block b",
        "block c"
      ]
    },
