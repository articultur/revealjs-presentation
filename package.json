{
  "name": "revealjs-presentation",
  "version": "15.0.0",
  "description": "Reveal.js 演示文稿生成技能 — 含可编辑 PPTX 导出",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "bootstrap": "bash scripts/install-all.sh",
    "install-all": "bash scripts/install-all.sh",
    "start": "npx http-server -p 4173 -c-1",
    "lint": "node scripts/lint-design.js",
    "lint:docs": "node scripts/lint-reference-docs.js",
    "lint:chrome": "node scripts/lint-template-chrome.js examples/template-*.html",
    "lint:all": "npm run lint:docs && npm run lint:chrome && for f in examples/template-*.html; do node scripts/lint-design.js \"$f\" || exit 1; done",
    "gate": "node scripts/grade-gate.js examples/template-*.html",
    "export-pptx": "node scripts/export-pptx.js",
    "visual-qa": "node scripts/visual-qa.js",
    "visual-verdict": "node scripts/visual-verdict.js",
    "qa": "node scripts/qa.js",
    "validate": "node scripts/validate.js",
    "test:validate-overflow": "node scripts/test-validate-overflow.js",
    "test:reference-contract": "node scripts/test-reference-contract.js",
    "test:launch-grade-contract": "node scripts/test-launch-grade-contract.js",
    "test:qa-system-contract": "node scripts/test-qa-system-contract.js",
    "test:off-template-regression": "node scripts/test-off-template-regression.js",
    "test:lint-main-claim": "node scripts/test-lint-main-claim.js examples/template-*.html",
    "test:initial-slide-visible": "node scripts/test-initial-slide-visible.js",
    "test:text-collision": "node scripts/test-text-collision.js examples/template-07-memphis.html",
    "test": "npm run test:validate-overflow && npm run test:reference-contract && npm run test:launch-grade-contract && npm run test:qa-system-contract && npm run test:off-template-regression && npm run test:lint-main-claim && npm run test:initial-slide-visible && npm run test:text-collision",
    "doctor": "bash scripts/doctor.sh"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "playwright": "^1.61.0",
    "pptxgenjs": "^4.0.1"
  }
}
